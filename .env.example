# Copy this file to .env and fill in your own values.
# .env is git-ignored, so your real key never gets committed.

# --- Self-contained Python agent (agent.py) ---

# Anthropic API key. Required to run the live agent loop.
# Without it, agent.py falls back to the offline --simulate walkthrough.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to drive the agent. Sonnet is fast/cheap for a multi-turn tool loop;
# claude-opus-4-8 is the more capable option.
ANTHROPIC_MODEL=claude-sonnet-5

# Mock service URLs (defaults match ./deploy.sh). Override only if you moved them.
PROMETHEUS_URL=http://localhost:9091
ELK_URL=http://localhost:9093
ANSIBLE_URL=http://localhost:9092

# --- Optional: Dify path (trigger_fault.py) ---

# Only needed if you run the alert against a Dify Workflow app instead of agent.py.
# Base URL of your Dify instance's API (note the /v1 suffix); local default http://localhost/v1
DIFY_API_BASE=http://localhost/v1
# API key of your Dify *Workflow* app (starts with "app-"), from the app's "API Access" page.
DIFY_WORKFLOW_API_KEY=app-your-workflow-api-key-here
