# Copy this file to .env and fill in your own values.
# .env is git-ignored, so your real key never gets committed.
#
# Pick ONE LLM backend below. The agent auto-detects whichever key is set.
# With none set, `agent.py` falls back to the offline --simulate walkthrough.

# --- Option A: Groq (recommended) ---------------------------------------------
# Free API key, no credit card. Get one at https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-free-groq-key-here
# GROQ_MODEL=llama-3.3-70b-versatile        # default; any Groq tool-use model works

# --- Option B: Google Gemini (free tier) ---------------------------------------
# Free API key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_MODEL=gemini-2.0-flash              # default

# --- Option C: Ollama (fully local, no key at all) ----------------------------
# Install from https://ollama.com, run `ollama pull llama3.1`, then set:
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1

# --- Option D: Anthropic (Claude) ---------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-5

# --- Option E: OpenAI or any OpenAI-compatible endpoint ------------------------
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- LLM fallback chain (comma-separated providers) ---------------------------
# Tried in order when the primary backend fails.
# LLM_FALLBACK_CHAIN=groq,openai,anthropic

# --- Mock service URLs (defaults match ./deploy.sh / ./start_services.sh) -----
PROMETHEUS_URL=http://localhost:9091
ELK_URL=http://localhost:9093
ANSIBLE_URL=http://localhost:9092

# --- Production hardening -----------------------------------------------------
# Incident timeout in seconds (default 300)
# AUTOSRE_TIMEOUT=300

# Approval gate for remediation: auto | prompt | webhook
# AUTOSRE_APPROVAL_MODE=auto
# AUTOSRE_APPROVAL_WEBHOOK_URL=http://localhost:9000/approve

# Independent rollback playbook if metrics remain unhealthy after remediation
# AUTOSRE_ROLLBACK_PLAYBOOK=restart_service.yml

# SQLite incident history path
# AUTOSRE_DB_PATH=autosre.db

# Webhook server port (python server.py)
# AUTOSRE_PORT=8080

# --- Optional: Dify path (trigger_fault.py), not required to run the project --
# DIFY_API_BASE=http://localhost/v1
# DIFY_WORKFLOW_API_KEY=app-your-workflow-api-key-here
